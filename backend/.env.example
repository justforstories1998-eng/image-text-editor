# ═══════════════════════════════════════
# Backend Configuration
# Copy this to .env and fill in values
# ═══════════════════════════════════════

PORT=5000
DEBUG=false
OCR_LANGS=en
OCR_GPU=false
MAX_IMAGE_MB=25
MAX_IMAGE_PIXELS=50000000
OUTPUT_FORMAT=PNG
JPEG_QUALITY=92
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*

# If deploying frontend separately, set the URL:
# ALLOWED_ORIGINS=https://your-app.netlify.app